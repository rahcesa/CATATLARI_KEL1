<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF6FF"
    android:padding="22dp"
    tools:context=".view.LoginFragment">

    <TextView
        android:id="@+id/txt_hello_world"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Selamat Datang"
        android:textColor="#0F172A"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txt_kelas_pemrograman"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Masuk untuk melanjutkan catatan larimu."
        android:textColor="#64748B"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@id/txt_hello_world"
        app:layout_constraintStart_toStartOf="@id/txt_hello_world"
        app:layout_constraintTop_toBottomOf="@id/txt_hello_world" />

    <LinearLayout
        android:id="@+id/form_login"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_kelas_pemrograman">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="#334155"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_bubble"
            android:hint="Masukkan email"
            android:inputType="textEmailAddress"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#0F172A"
            android:textColorHint="#94A3B8"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Password"
            android:textColor="#334155"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_bubble"
            android:hint="Masukkan password"
            android:inputType="textPassword"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#0F172A"
            android:textColorHint="#94A3B8"
            android:textSize="15sp" />

    </LinearLayout>

    <Button
        android:id="@+id/button_login"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginTop="30dp"
        android:backgroundTint="#2563EB"
        android:text="Masuk"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/form_login" />

</androidx.constraintlayout.widget.ConstraintLayout>