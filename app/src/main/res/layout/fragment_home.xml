<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF6FF"
    android:padding="22dp"
    tools:context=".view.HomeFragment">

    <TextView
        android:id="@+id/welcoming_txt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Halo!"
        android:textColor="#0F172A"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/ask_txt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Yuk catat progres larimu hari ini"
        android:textColor="#64748B"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@id/welcoming_txt"
        app:layout_constraintStart_toStartOf="@id/welcoming_txt"
        app:layout_constraintTop_toBottomOf="@id/welcoming_txt" />

    <LinearLayout
        android:id="@+id/header_history"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/ask_txt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txt_history_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Riwayat Lari"
            android:textColor="#334155"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnEditMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit"
            android:textColor="#2563EB"
            android:textStyle="bold"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_run_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        tools:listitem="@layout/item_run"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_history" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/floating_btn_add_run"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#2563EB"
        android:contentDescription="Tambah catatan lari"
        app:srcCompat="@drawable/ic_add"
        app:tint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>